# Suprimir display_errors para el endpoint PDF
php_flag display_errors off
php_value error_reporting E_ALL & ~E_WARNING & ~E_NOTICE & ~E_DEPRECATED

# Tiempo máximo de ejecución (Dompdf puede tardar)
php_value max_execution_time 120
php_value memory_limit 256M

# Permitir acceso directo
<Files "generar_kardex.php">
    Order Allow,Deny
    Allow from all
</Files>

# Denegar acceso a otros archivos PHP
<FilesMatch "\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Excepción solo para generar_kardex.php
<Files "generar_kardex.php">
    Order Allow,Deny
    Allow from all
</Files>

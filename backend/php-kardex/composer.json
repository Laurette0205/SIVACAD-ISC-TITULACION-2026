{
    "name": "sivacad/kardex-pdf",
    "description": "Generador PDF y Excel del Kardex Academico",
    "type": "project",
    "require": {
        "dompdf/dompdf": "^3.1",
        "endroid/qr-code": "^6.0",
        "phpoffice/phpspreadsheet": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "Sivacad\\Kardex\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "echo 'Dependencias instaladas correctamente'"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
